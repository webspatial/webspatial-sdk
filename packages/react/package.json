{
  "name": "@webspatial/react-sdk",
  "version": "1.7.0",
  "description": "React components for WebSpatial",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/index.js",
    "./dist/eager.js",
    "./dist/spatial.js",
    "./src/eager.ts",
    "./src/runtime/registerEagerEntry.ts",
    "./src/spatial/index.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./eager": {
      "types": "./dist/eager.d.ts",
      "default": "./dist/eager.js"
    },
    "./spatial": {
      "types": "./dist/spatial.d.ts",
      "default": "./dist/spatial.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx/jsx-runtime.d.ts",
      "default": "./dist/jsx/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx/jsx-dev-runtime.js"
    },
    "./internal/facades-client": {
      "types": "./dist/internal/facades-client.d.ts",
      "default": "./dist/internal/facades-client.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "tsc -p ./tsconfig.json && tsup && vitest run",
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "npm run dev",
    "format": "npx prettier --write 'src/**/*.ts' 'src/**/*.tsx' || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webspatial/webspatial-sdk.git",
    "directory": "packages/react"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/webspatial/webspatial-sdk/issues"
  },
  "homepage": "https://github.com/webspatial/webspatial-sdk#readme",
  "dependencies": {
    "@webspatial/core-sdk": "workspace:^"
  },
  "peerDependencies": {
    "@webspatial/core-sdk": "^1.8.0",
    "react": ">=18.0",
    "react-dom": ">=18.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/types": "^7.29.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/unist": "^3.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitejs/plugin-react": "^4.4.1",
    "@webspatial/core-sdk": "workspace:*",
    "esbuild": "^0.25.0",
    "esbuild-plugin-d.ts": "^1.3.1",
    "esbuild-plugin-define": "^0.5.0",
    "jsdom": "^24.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-glob": "^0.2.9",
    "tsup": "^8.4.0",
    "typedoc": "^0.26.5",
    "typedoc-plugin-markdown": "^4.2.2",
    "typescript": "^5.5.4",
    "vite": "6.4.2",
    "vitest": "^4.1.8"
  }
}
