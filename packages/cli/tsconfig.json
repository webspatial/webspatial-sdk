{
  "compilerOptions": {
    "allowJs": true,
    "target": "es2018",
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
